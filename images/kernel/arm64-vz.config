# script-jail VZ kbuild config for arm64 — do not regenerate casually.
#
# Hand-curated to be the smallest config that boots under Apple's
# Virtualization.framework via objc2-virtualization.  See
# images/kernel/build.sh for the build pipeline that consumes this file.
# `make olddefconfig` runs over this file after copy so kernel-version
# changes pick up new mandatory CONFIG_* keys without an edit here.
#
# This is the arm64 sibling of x86_64-vz.config — see that file's header
# for the design rationale.  arm64 differs in three ways:
#   - CONFIG_ARM64 and the canonical 4-kB / 48-bit-VA page-table setup
#     are mandatory (the apple-silicon hosts VZ runs on use these pagings)
#   - the GICv3 interrupt controller (objc2-virtualization wires this up)
#   - no PCI-MSI; arm64 uses ARM64_MSI/ITS instead

# --- Core architecture -------------------------------------------------------
CONFIG_64BIT=y
CONFIG_ARM64=y
CONFIG_SMP=y
CONFIG_ARM64_4K_PAGES=y
CONFIG_ARM64_VA_BITS_48=y

# --- Interrupt controllers ---------------------------------------------------
CONFIG_ARM_GIC=y
CONFIG_ARM_GIC_V3=y
CONFIG_ARM_GIC_V3_ITS=y

# --- VZ-required: PCI bus ----------------------------------------------------
CONFIG_PCI=y
CONFIG_PCI_HOST_GENERIC=y

# --- virtio drivers ----------------------------------------------------------
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VSOCKETS=y
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

# --- Block + filesystems -----------------------------------------------------
CONFIG_BLOCK=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# --- TTY + serial console ----------------------------------------------------
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
# arm64 server-class kernels also enable AMBA PL011 — VZ doesn't surface
# one but olddefconfig may auto-enable; harmless when unused.
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# --- Networking baseline -----------------------------------------------------
# CONFIG_NETDEVICES is `default y if UML` upstream — i.e. it defaults to *n*
# on every non-UML build.  `make olddefconfig` therefore silently drops it
# (and with it everything under `if NETDEVICES`, INCLUDING CONFIG_VIRTIO_NET)
# unless it is set explicitly here.  Without this line the guest boots with
# no eth0 and Phase A's `vp env install` cannot reach the network.
CONFIG_NET=y
CONFIG_NETDEVICES=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_UNIX=y

# --- Userspace ABI -----------------------------------------------------------
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_MULTIUSER=y
CONFIG_FUTEX=y
CONFIG_SHMEM=y
CONFIG_POSIX_TIMERS=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_EPOLL=y

# --- Modern userspace (systemd/cgroup-v2) ------------------------------------
CONFIG_CGROUPS=y
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# --- Trim ---------------------------------------------------------------------
# Modules are NOT used in the VZ rootfs — every required driver is
# built-in.  Disabling the module loader trims init time and rootfs size.
# CONFIG_MODULES is not set
