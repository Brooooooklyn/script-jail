# script-jail VZ kbuild config for x86_64 — do not regenerate casually.
#
# Hand-curated to be the smallest config that boots under Apple's
# Virtualization.framework via objc2-virtualization.  See
# images/kernel/build.sh for the build pipeline that consumes this file.
# `make olddefconfig` runs over this file after copy so kernel-version
# changes pick up new mandatory CONFIG_* keys without an edit here.
#
# What this enables:
#   - Core: 64-bit, SMP, common architectural baseline
#   - virtio over PCI (Firecracker uses MMIO; VZ uses PCI)
#   - virtio-blk / virtio-net / virtio-vsock / virtio-rng
#   - ext4 + tmpfs + procfs + sysfs
#   - 8250 serial console (objc2-virtualization wires up a VirtioConsole;
#     8250 is the kernel fallback when the framework's console
#     attachment uses the serial port mapping)
#   - basic networking stack (eth0 / IPv4)
#   - cgroup v2 (modern userspace requires it)
#
# What this leaves off:
#   - all modules except virtio (CONFIG_MODULES=n simplifies the rootfs)
#   - WiFi/Bluetooth/USB
#   - sound, graphics
#   - block device drivers other than virtio-blk
#   - filesystem drivers other than ext4 + tmpfs
#   - debug/tracing options
#
# Adding a new option:
#   Append the CONFIG_<NAME>=y line; run `make olddefconfig` once in a
#   scratch checkout to canonicalise ordering; copy the new ordering back
#   here.  Do NOT manually re-run defconfig — the resulting kernel would
#   be much larger and slower to boot.

# --- Core architecture -------------------------------------------------------
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_X86_X2APIC=y

# --- VZ-required: PCI bus ----------------------------------------------------
CONFIG_PCI=y
CONFIG_PCI_MSI=y

# --- virtio drivers ----------------------------------------------------------
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VSOCKETS=y
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

# --- Block + filesystems -----------------------------------------------------
CONFIG_BLOCK=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# --- TTY + serial console ----------------------------------------------------
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# --- Networking baseline -----------------------------------------------------
# CONFIG_NETDEVICES is `default y if UML` upstream — i.e. it defaults to *n*
# on every non-UML build.  `make olddefconfig` therefore silently drops it
# (and with it everything under `if NETDEVICES`, INCLUDING CONFIG_VIRTIO_NET)
# unless it is set explicitly here.  Without this line the guest boots with
# no eth0 and Phase A's `vp env install` cannot reach the network.
CONFIG_NET=y
CONFIG_NETDEVICES=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_UNIX=y

# --- Userspace ABI -----------------------------------------------------------
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_MULTIUSER=y
CONFIG_FUTEX=y
CONFIG_SHMEM=y
CONFIG_POSIX_TIMERS=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_EPOLL=y

# --- Modern userspace (systemd/cgroup-v2) ------------------------------------
CONFIG_CGROUPS=y
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# --- Trim ---------------------------------------------------------------------
# Modules are NOT used in the VZ rootfs — every required driver is
# built-in.  Disabling the module loader trims init time and rootfs size.
# CONFIG_MODULES is not set
